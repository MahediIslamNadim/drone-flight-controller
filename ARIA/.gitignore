# =============================================================
# ARIA — .gitignore
# =============================================================

# ── Credentials & API keys (NEVER commit these) ──────────────
.env
*.json
!package.json
!package-lock.json

# ── Python cache ─────────────────────────────────────────────
__pycache__/
*.py[cod]
*.pyo
*.pyd
.Python
*.egg
*.egg-info/
dist/
build/
*.spec

# ── Virtual environments ──────────────────────────────────────
venv/
.venv/
env/
ENV/

# ── PyInstaller / bundled EXE output ─────────────────────────
*.exe
*.dll
*.pyd
*.zip
*.so
SDL2*.dll
VCRUNTIME*.dll
api-ms-win-*.dll
ucrtbase.dll
libcrypto*.dll
libssl*.dll
libffi*.dll
libpng*.dll
libjpeg*.dll
libtiff*.dll
libwebp*.dll
libogg*.dll
libopus*.dll
libopusfile*.dll
libmodplug*.dll
freetype.dll
portmidi.dll
zlib1.dll
python*.dll
sqlite3.dll

# ── Bundled Python packages (too heavy for version control) ──
aiohttp/
alabaster/
attrs*/
babel/
cachecontrol*/
certifi/
charset_normalizer/
click*/
cryptography/
cv2/
