pygame/
pypdfium2/
pypdfium2_raw/
pyreadline3*/
pyrebase/
pyrebase4*/
python_jwt/
pyttsx3/
pyttsx3*/
pytz/
pywhatkit/
pywhatkit*/
pywin32_system32/
rapidfuzz/
setuptools/
sphinx/
tzdata/
websockets/
werkzeug*/
win32/
win32com/
winrt/
yaml/
yarl/
yt_dlp/
zstandard/
Levenshtein/
Crypto/
Pythonwin/
_sounddevice_data/

# ── Bundled .pyd extension modules ───────────────────────────
*.pyd

# ── Compiled/minified files ───────────────────────────────────
base_library.zip

# ── dist-info directories ─────────────────────────────────────
*.dist-info/

# ── IDE & OS ─────────────────────────────────────────────────
.vscode/
.idea/
*.swp
*.swo
*~
Thumbs.db
.DS_Store
desktop.ini

# ── Logs & temp output ────────────────────────────────────────
*.log
out.wav
*.wav
*.mp3
*.tmp

# ── ARIA memory/data (user-specific, not source code) ────────
aria_modules/aria_memory/
